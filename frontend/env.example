# Dev server port. 3000 is avoided because Windows (Hyper-V/Docker winnat) often
# reserves the 2917-3016 range, which makes react-scripts fail to bind port 3000.
# 3100 is outside the reserved ranges.
PORT=3100

# API Configuration
REACT_APP_API_URL=http://localhost:8080

# Application Configuration
REACT_APP_NAME=Mobility Rental Platform
REACT_APP_VERSION=1.0.0

# Map Configuration (Optional)
REACT_APP_MAP_CENTER_LAT=40.7128
REACT_APP_MAP_CENTER_LNG=-74.0060
REACT_APP_MAP_DEFAULT_ZOOM=12

# Feature Flags
REACT_APP_ENABLE_DRIVER_FEATURE=true
REACT_APP_ENABLE_REVIEWS=true






